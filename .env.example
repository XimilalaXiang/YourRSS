# FreshRSS (Required)
FRESHRSS_URL=https://your-freshrss-instance.com
FRESHRSS_USER=your-username
FRESHRSS_API_PASSWORD=your-api-password

# Cortex Memory (Required)
CORTEX_URL=http://localhost:21100
