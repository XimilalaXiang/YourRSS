# FreshRSS (Required)
FRESHRSS_URL=https://your-freshrss-instance.com
FRESHRSS_USER=your-username
FRESHRSS_API_PASSWORD=your-api-password

# Cortex Memory (Required)
CORTEX_URL=http://localhost:21100
CORTEX_TOKEN=your-cortex-auth-token
CORTEX_AGENT=reader

# AI Scoring Provider (Optional)
# agent  = Agent handles scoring directly (use when Agent has unlimited tokens, e.g. Cursor)
# openai = Call an external OpenAI-compatible API for scoring (use to save Agent tokens)
AI_PROVIDER=agent
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Blinko (Optional)
BLINKO_URL=http://localhost:1111
BLINKO_TOKEN=your-blinko-api-token
